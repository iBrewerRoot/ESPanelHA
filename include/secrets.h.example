#pragma once
/*
 * Local credentials override.
 *
 * Copy this file to  include/secrets.h  (gitignored) and fill in your values.
 *
 * When WIFI_SSID is defined, the firmware connects directly with these
 * credentials instead of opening the WiFiManager captive portal. This:
 *   - works with HIDDEN networks (the portal can't list them),
 *   - avoids any password mangling by the web form,
 *   - speeds up development (no re-provisioning on every flash).
 *
 * Define the HA_* values too to skip the web entry of Home Assistant settings.
 * Comment everything out to fall back to the captive portal.
 */

#define WIFI_SSID "YourWiFiName"
#define WIFI_PASS "YourWiFiPassword"

// Optional — Home Assistant connection (skips portal entry when set):
// #define HA_HOST  "192.168.1.50"
// #define HA_PORT  8123
// #define HA_TOKEN "your-long-lived-access-token"
